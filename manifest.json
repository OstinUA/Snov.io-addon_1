{
  "manifest_version": 3,
  "name": "Snov.io addon_1",
  "version": "1.1.0",
  "description": "Highlighting from Google Sheets",
  "permissions": [],
  "host_permissions": [
    "https://app.snov.io/*",
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [ "https://app.snov.io/*" ],
      "js": [ "content.js" ],
      "run_at": "document_end"
    }
  ]
}