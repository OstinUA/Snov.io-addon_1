{
  "manifest_version": 3,
  "name": "Snov.io addon_1",
  "version": "1.2.1",
  "description": "Highlighting from Google Sheets with custom colors",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://app.snov.io/*",
    "https://docs.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [ "https://app.snov.io/*" ],
      "js": [ "content.js" ],
      "run_at": "document_end"
    }
  ]
}
